{
  "name": "repo-to-pdf",
  "version": "0.1.11",
  "description": "make pdf from a repo of source code",
  "main": "src/index.js",
  "bin": {
    "repo-to-pdf": "src/bin/index.js"
  },
  "scripts": {
    "test": "npm run clean:test && jest --forceExit; status=$?; npm run clean:test; exit $status",
    "clean:test": "rm -f self*.html self*.pdf self*.mobi self*.epub redis*.html redis*.pdf redis*.mobi redis*.epub",
    "format": "eslint \"**/*.js\" --fix && prettier \"**/*.{js,json,md}\" --write",
    "format:staged": "eslint \"**/*.js\" --fix && pretty-quick --staged --verbose --pattern \"**/*.{js,json,md}\"",
    "format:check": "eslint \"**/*.js\" && prettier --check \"**/*.{js,json,md}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/josherich/repo-to-pdf.git"
  },
  "keywords": [
    "pdf",
    "github",
    "repository"
  ],
  "author": "josherich",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/josherich/repo-to-pdf/issues"
  },
  "homepage": "https://github.com/josherich/repo-to-pdf#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^4.0.0",
    "highlight.js": "^10.7.3",
    "puppeteer": "^24.43.1",
    "remarkable": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "eslint": "^9.21.0",
    "globals": "^16.0.0",
    "jest": "^30.4.2",
    "prettier": "^3.5.3",
    "pretty-quick": "^4.2.2"
  }
}
